# Puerto HTTP del servicio (por defecto 8080)
PORT=8080

# Prefijo de ruta del servicio (ingress), sin barra final. Ej.: /karia-svc/v2 → API en /karia-svc/v2/api/...
# Vacío = rutas en raíz (/api/..., /health).
SERVICE_BASE_PATH=/karia-svc/v2

# Cadena de conexión PostgreSQL (Supabase, Cloud SQL, local, etc.)
# Si no se define, los endpoints /api/db/* fallan pero el server arranca igual.
# Formato: postgresql://usuario:contraseña@host:5432/nombre_bd?sslmode=require
ConnectionString_Karia=postgresql://user:pass@localhost:5432/postgres

# API key de Gemini (usada por endpoints server-side)
GEMINI_API_KEY=your-gemini-api-key-here

# Credenciales de Google Cloud (opcional en dev si no usas /api/library)
# Apunta a un JSON de Service Account con acceso al bucket "aria-library-files"
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\al\service-account.json
