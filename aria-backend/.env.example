# Puerto HTTP: por defecto en código es 3000 (local). Cloud Run / imagen Docker usan 8080.
PORT=3000

# El prefijo de la API está fijado en código: `src/index.ts` → `/karia-svc/v2/`.
# Liveness sigue en la raíz: `GET /health`.

# Cadena de conexión PostgreSQL (directo al servidor: Supabase, Neon, RDS, local, etc.)
# Si no se define, los endpoints que tocan BD fallan pero el server arranca igual.
# Formato típico con TLS: postgresql://usuario:contraseña@host:5432/nombre_bd?sslmode=require
ConnectionString_Karia=postgresql://user:pass@localhost:5432/postgres

# TLS hacia Postgres (Node verifica la cadena por defecto).
# Si ves "self-signed certificate in certificate chain":
#   - Recomendado: descargá el CA del proveedor y definí DB_SSL_CA=ruta/al/archivo.pem
#   - Solo dev / red de confianza: DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA=C:\ruta\ca-bundle.pem
# DB_SSL_REJECT_UNAUTHORIZED=false

# Bucket de biblioteca / artefactos (GCP). Producción FinOps: karia-library-files
GCS_BUCKET_NAME=karia-library-files

# Credenciales de Google Cloud (opcional en dev si no usas /library ni /artifacts)
# La cuenta de servicio debe tener permisos sobre el bucket indicado en GCS_BUCKET_NAME
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\al\service-account.json
